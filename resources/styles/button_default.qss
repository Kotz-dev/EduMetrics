QPushButton {
	background-color: rgb(94, 92, 100);
    border-radius : 5px;
	color: rgb(255, 255, 255);
}
QPushButton:hover {
	background-color: rgb(36, 31, 49);
    border-radius:5px;
     color: rgb(255, 255, 255);
}
QPushButton:pressed {
	background-color: rgb(0, 0, 0);
    color: rgb(255, 255, 255);
}